    "#question 12\n",
    "class IsoscelesTriangle:\n",
    "    def __init__(self, a, b, c):\n",
    "        self.a, self.b, self.c = a, b, c\n",
    "    \n",
    "    def is_isosceles(self):\n",
    "        return self.a == self.b or self.b == self.c or self.a == self.c\n",
    "\n",
    "\n",
    "class RightTriangle:\n",
    "    def __init__(self, a, b, c):\n",
    "        self.a, self.b, self.c = a, b, c\n",
    "    \n",
    "    def is_right(self):\n",
    "        sides = sorted([self.a, self.b, self.c])\n",
    "        return sides[0]**2 + sides[1]**2 == sides[2]**2\n",
    "\n",
    "\n",
    "class IsoscelesRightTriangle(IsoscelesTriangle, RightTriangle):\n",
    "    def __init__(self, a, b, c):\n",
    "        IsoscelesTriangle.__init__(self, a, b, c)\n",
    "        RightTriangle.__init__(self, a, b, c)\n",
    "    \n",
    "    def check(self):\n",
    "        return self.is_isosceles() and self.is_right()\n",
    "\n",
    "\n",
    "# 🔎 Example\n",
    "t = IsoscelesRightTriangle(5, 5, (5**2 + 5**2)**0.5)\n",
    "print(\"Is isosceles right triangle?\", t.check())"
   ]
